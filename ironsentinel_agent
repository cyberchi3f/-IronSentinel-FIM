# PROCESS CONTEXT COLLECTOR
# =============================================================================

class ProcessContextCollector:
    """
    Uses psutil to identify which process is touching a monitored file.
    Returns a best-effort context dict; never raises exceptions to callers.
    """

    @staticmethod
    def get_context_for_path(file_path: str) -> Dict[str, Any]:
        ctx: Dict[str, Any] = {
            "pid":          None,
            "process_name": "Unknown",
            "exe_path":     "Unknown",
            "username":     "Unknown",
            "cmdline":      "Unknown",
            "session_type": "UNKNOWN",
            "create_time":  None,
        }

        try:
            fp_lower = file_path.lower()
            for proc in psutil.process_iter(
                ["pid", "name", "exe", "username", "cmdline", "create_time"]
            ):
                try:
                    info = proc.info
                    # Attempt open-file inspection (may raise AccessDenied)
                    for of in proc.open_files():
                        if of.path.lower() == fp_lower:
                            ctime = info.get("create_time")
                            ctx.update({
                                "pid":          info["pid"],
                                "process_name": info.get("name") or "Unknown",
                                "exe_path":     info.get("exe")  or "Unknown",
                                "username":     info.get("username") or "Unknown",
                                "cmdline":      " ".join(info.get("cmdline") or []),
                                "create_time":  (
                                    datetime.fromtimestamp(ctime).isoformat()
                                    if ctime else None
                                ),
                            })
                            break
                except (psutil.AccessDenied, psutil.NoSuchProcess, OSError):
                    pass
        except Exception:
            pass

        # Classify session type from username string
        try:
            uname = ctx.get("username", "").upper()
            if "SYSTEM" in uname:
                ctx["session_type"] = "SYSTEM"
            elif "LOCAL SERVICE" in uname or "NETWORK SERVICE" in uname:
                ctx["session_type"] = "SERVICE"
            elif uname not in ("", "UNKNOWN"):
                ctx["session_type"] = "INTERACTIVE"
        except Exception:
            pass

        return ctx

    @staticmethod
    def current_username() -> str:
        try:
            return psutil.Process().username()
        except Exception:
            return "Unknown"


# =============================================================================
# ACL MONITOR
# =============================================================================

class ACLMonitor:
    """
    Reads Windows DACL (Discretionary Access Control List) via pywin32.
    If pywin32 is not installed, all methods return None/Unknown and
    the rest of the tool continues without ACL-change detection.
    """

    @staticmethod
    def get_sddl(path: str) -> Optional[str]:
        """Return SDDL string for the file's DACL + owner, or None."""
        if not _WIN32_AVAILABLE or not os.path.exists(path):
            return None
        try:
            sd = win32security.GetFileSecurity(
                path,
                win32security.DACL_SECURITY_INFORMATION |
                win32security.OWNER_SECURITY_INFORMATION,
            )
            return sd.GetSecurityDescriptorSddl(
                win32security.DACL_SECURITY_INFORMATION |
                win32security.OWNER_SECURITY_INFORMATION,
            )
        except Exception:
            return None

    @staticmethod
    def get_owner(path: str) -> str:
        if not _WIN32_AVAILABLE or not os.path.exists(path):
            return "N/A (pywin32 not installed)" if not _WIN32_AVAILABLE else "Unknown"
        try:
            sd     = win32security.GetFileSecurity(path, win32security.OWNER_SECURITY_INFORMATION)
            sid    = sd.GetSecurityDescriptorOwner()
            name, domain, _ = win32security.LookupAccountSid(None, sid)
            return f"{domain}\\{name}"
        except Exception:
            return "Unknown"


# =============================================================================
# BASELINE MANAGER
# =============================================================================

class BaselineManager:
    """
    Maintains a persistent JSON snapshot of monitored file metadata:
    SHA-256 hash, size, mtime, ctime, SDDL (ACL), owner.

    On-disk format:
      {
        "meta": { "created": ..., "tool": ..., "version": ... },
        "entries": { "<absolute_path>": { ... } }
      }
    """

    def __init__(self, config: Config) -> None:
        self.config       = config
        self.baseline_file = config.get("baseline", "file",
                                        default="ironsentinel_baseline.json")
        self.hash_algo    = config.get("baseline", "hash_algorithm", default="sha256")
        self.baseline:    Dict[str, Dict] = {}
        self._acl         = ACLMonitor()
        self._lock        = threading.Lock()

    # ------------------------------------------------------------------
    # Hashing & metadata collection
    # ------------------------------------------------------------------

    def hash_file(self, path: str) -> Optional[str]:
        """Return hex digest, or None on read error (e.g. locked file)."""
        try:
            h = hashlib.new(self.hash_algo)
            with open(path, "rb") as fh:
                for chunk in iter(lambda: fh.read(1 << 16), b""):
                    h.update(chunk)
            return h.hexdigest()
        except (PermissionError, FileNotFoundError, OSError):
            return None

    def collect_metadata(self, path: str) -> Dict[str, Any]:
        meta: Dict[str, Any] = {
            "exists": False, "is_dir": False,
            "hash": None,    "size": None,
            "mtime": None,   "ctime": None,
            "acl":  None,    "owner": None,
        }
        try:
            if not os.path.exists(path):
                return meta
            stat    = os.stat(path)
            is_dir  = os.path.isdir(path)
            meta.update({
                "exists": True,
                "is_dir": is_dir,
                "hash":   self.hash_file(path) if not is_dir else None,
                "size":   stat.st_size,
                "mtime":  stat.st_mtime,
                "ctime":  stat.st_ctime,
                "acl":    self._acl.get_sddl(path),
                "owner":  self._acl.get_owner(path),
            })
        except Exception:
            pass
        return meta

    # ------------------------------------------------------------------
    # Create baseline
    # ------------------------------------------------------------------

    def create_baseline(self, paths: List[str], recursive: bool = True) -> int:
        """Scan all given paths and populate self.baseline. Returns file count."""
        count = 0
        with self._lock:
            for base in paths:
                base = os.path.expandvars(base)
                if os.path.isfile(base):
                    self.baseline[base] = self.collect_metadata(base)
                    count += 1
                elif os.path.isdir(base):
                    iterator = (
                        (os.path.join(r, f)
                         for r, _, files in os.walk(base)
                         for f in files)
                        if recursive
                        else (os.path.join(base, item)
                              for item in os.listdir(base))
                    )
                    for fpath in iterator:
                        try:
                            self.baseline[fpath] = self.collect_metadata(fpath)
                            count += 1
                        except Exception:
                            pass
        return count

    # ------------------------------------------------------------------
    # Persistence
    # ------------------------------------------------------------------

    def save(self) -> bool:
        try:
            payload = {
                "meta": {
                    "created": datetime.now().isoformat(),
                    "tool":    TOOL_NAME,
                    "version": VERSION,
                    "entries": len(self.baseline),
                },
                "entries": self.baseline,
            }
            with open(self.baseline_file, "w", encoding="utf-8") as fh:
                json.dump(payload, fh, indent=2)
            logging.info(f"Baseline saved → {self.baseline_file} ({len(self.baseline)} entries)")
            return True
        except Exception as exc:
            logging.error(f"Baseline save failed: {exc}")
            return False

    def load(self) -> bool:
        if not os.path.exists(self.baseline_file):
            return False
        try:
            with open(self.baseline_file, "r", encoding="utf-8") as fh:
                data = json.load(fh)
            self.baseline = data.get("entries", {})
            logging.info(f"Baseline loaded ← {self.baseline_file} ({len(self.baseline)} entries)")
            return True
        except Exception as exc:
            logging.error(f"Baseline load failed: {exc}")
            return False

    # ------------------------------------------------------------------
    # Comparison
    # ------------------------------------------------------------------

    def diff(self, path: str) -> Optional[Dict]:
        """
        Compare a file's current state to the baseline.
        Returns a diff dict, or None if nothing changed.
        """
        current = self.collect_metadata(path)

        if path not in self.baseline:
            if current["exists"]:
                return {"type": "NEW_FILE", "path": path, "changes": [], "current": current, "baseline": None}
            return None

        base = self.baseline[path]

        if not current["exists"] and base.get("exists"):
            return {"type": "FILE_DELETED", "path": path, "changes": ["FILE_REMOVED"], "current": current, "baseline": base}

        changes: List[str] = []

        if base.get("hash") and current.get("hash") and base["hash"] != current["hash"]:
            changes.append("HASH_CHANGED")

        if base.get("size") is not None and current.get("size") is not None:
            if base["size"] != current["size"]:
                changes.append("SIZE_CHANGED")

        if base.get("mtime") and current.get("mtime"):
            if abs(base["mtime"] - current["mtime"]) > 1.5:
                changes.append("MTIME_CHANGED")

        if base.get("acl") and current.get("acl") and base["acl"] != current["acl"]:
            changes.append("ACL_CHANGED")

        if base.get("owner") and current.get("owner") and base["owner"] != current["owner"]:
            changes.append("OWNER_CHANGED")

        if changes:
            return {"type": "FILE_MODIFIED", "path": path, "changes": changes,
                    "current": current, "baseline": base}
        return None

    def update_entry(self, path: str) -> None:
        """Refresh a single baseline entry after processing an event."""
        with self._lock:
            self.baseline[path] = self.collect_metadata(path)


